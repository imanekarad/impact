        "item_hzNLGm": {
          "type": "item",
          "settings": {
            "title": "Are there any side effects?",
            "content": "<p>PhytoseedLabs is made with carefully selected ingredients and is generally well tolerated when taken as directed. As with any dietary supplement, individual responses may vary. We recommend take 1 softgel per day during 1 week.  If you  are pregnant or breastfeeding we recommend consulting your healthcare professional before use.</p>"
          }
