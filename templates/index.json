        "166442457738b23caf-0": {
          "type": "item",
          "settings": {
            "title": "Description",
            "content": "<p>Phytoseed Labs. is a powerful, clean supplement designed to support your immune system, gut health, and overall well-being.<br/><br/>Each softgel combines concentrated oregano oil extract with black seed oil (200 mg)—two clinically studied ingredients to support your body's natural defenses.<br/><br/>No fillers. No aftertaste.</p><p>Whether you’re looking to support your immune system, ease digestive discomfort, or maintain daily wellness—Phytoseed Labs was made for you.</p><p>This daily formula helps your body stay strong, balanced, and resilient—all from two powerful plants used for centuries and now informed by modern research.</p>"
          }
        },
        "166442457738b23caf-1": {
          "type": "item",
          "settings": {
            "title": "Benefits",
            "content": "<ul><li>Supports a strong immune response</li><li>Supports digestive comfort and reduced bloating</li><li>Supports your body’s natural defenses</li><li>Supports daily energy and mental clarity</li><li>Easy-to-swallow, tasteless softgels</li><li>Free from gluten, dairy, soy, sugar, and artificial additives</li></ul><h6>Hormonal Balance & Fertility SupportBlack seed oil is often used in holistic wellness for:</h6><h6><br/>PCOS support<br/>menstrual balance<br/>inflammation reduction<br/></h6><p>Some research and wellness communities also discuss support for:</p><p>sperm mobility<br/>reproductive wellness</p><p>These statements have not been evaluated by the FDA. This product is not intended to diagnose, treat, cure, or prevent any disease.</p>"
          }
        },
        "166442457738b23caf-2": {
          "type": "item",
          "settings": {
            "title": "Recommended use",
            "content": "<p>Take 1 softgel daily with water, preferably with food. Consistent daily use is recommended for best results. After 2 weeks, you can start taking 2 softgels daily.</p><p>Most customers report noticing a difference within 2–3 weeks of consistent use.*</p><p>* Individual results may vary. Consult your healthcare provider before use if you are pregnant, nursing, taking medication, or have a medical condition.</p>"
          }
        },
        "item_yRx3Yi": {
          "type": "item",
          "settings": {
            "title": "Ingredients",
            "content": "<p>Oil of Oregano (<em>Origanum vulgare</em>) — 6,000 mg (standardized to 80% carvacrol and 5% thymol)<br/>Black Seed Oil (<em>Nigella sativa</em>) — 200 mg</p><p>Other ingredients: Softgel shell (gelatin, glycerin, purified water). Contains no fillers, binders, artificial colors, or preservatives.</p><p>Free from: Gluten, dairy, soy, sugar, GMOs, artificial additives.</p>"
          }
        }
