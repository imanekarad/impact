      "default": "Discover the formula"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien du bouton"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond",
      "default": "#0f0e0c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte principal",
      "default": "#f5efe6"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Texte att√©nu√©",
      "default": "#9a8f82"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur accent (eyebrow + CTA)",
      "default": "#c8a96e"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Couleur highlight (phrase 2)",
      "default": "#c8a96e"
    },
    {
      "type": "color",
      "id": "orb_color_a",
      "label": "Orbe ambiant gauche",
      "default": "#4a3728"
    },
    {
      "type": "color",
      "id": "orb_color_b",
      "label": "Orbe ambiant droit",
      "default": "#2d4a35"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut (px)",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas (px)",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "Gut Health Statement"
    }
  ]
}
{% endschema %}

