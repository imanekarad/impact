<script>
(function(){
  const track   = document.getElementById('pslTrack');
  const dotsWrap= document.getElementById('pslDots');
  const btnPrev = document.getElementById('pslPrev');
  const btnNext = document.getElementById('pslNext');

  const cards   = track.querySelectorAll('.psl-card');
  const total   = cards.length;
  let current   = 0;

  /* ‚îÄ‚îÄ Responsive: combien de cartes visibles ? ‚îÄ‚îÄ */
  function perView(){
    const w = window.innerWidth;
    if(w <= 580) return 1;
    if(w <= 900) return 2;
    return 3;
  }

  function pages(){ return Math.ceil(total / perView()); }

  /* ‚îÄ‚îÄ Cr√©e les dots ‚îÄ‚îÄ */
  function buildDots(){
    dotsWrap.innerHTML = '';
    for(let i=0; i<pages(); i++){
      const d = document.createElement('button');
      d.className = 'psl-dot' + (i===current?' active':'');
      d.setAttribute('aria-label','Page '+(i+1));
      d.addEventListener('click',()=>goTo(i));
      dotsWrap.appendChild(d);
    }
  }

  /* ‚îÄ‚îÄ Calcule le d√©calage ‚îÄ‚îÄ */
  function cardWidth(){
    if(!cards[0]) return 0;
    return cards[0].getBoundingClientRect().width + 16; // gap 16
  }

  function goTo(page){
    const p = Math.max(0, Math.min(page, pages()-1));
    current = p;
    const offset = p * perView() * cardWidth();
    track.style.transform = `translateX(-${offset}px)`;
    dotsWrap.querySelectorAll('.psl-dot').forEach((d,i)=>{
      d.classList.toggle('active', i===current);
    });
  }

  btnPrev.addEventListener('click',()=> goTo(current-1));
  btnNext.addEventListener('click',()=> goTo(current+1));

  /* ‚îÄ‚îÄ Init + resize ‚îÄ‚îÄ */
  buildDots();
  let resizeTimer;
  window.addEventListener('resize',()=>{
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(()=>{ buildDots(); goTo(0); }, 150);
  });

  /* ‚îÄ‚îÄ Auto-play toutes les 5s ‚îÄ‚îÄ */
  setInterval(()=>{
    const next = (current + 1) >= pages() ? 0 : current + 1;
    goTo(next);
  }, 5000);
})();
</script>

