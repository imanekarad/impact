<style>
#psl-section {
  --psl-green: #085946;
  --psl-star: #00B67A;
  --psl-bg: #ffffff;
  --psl-card-bg: #f9fdfb;
  --psl-text: #0d2b22;
  --psl-muted: #6b7280;
  --psl-border: #e2ece7;
  --psl-radius: 14px;
  background: var(--psl-bg);
  padding: 64px 24px 72px;
  font-family: var(--font-body-family, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
  overflow: hidden;
  box-sizing: border-box;
}

/* ‚îÄ‚îÄ HEADER ‚îÄ‚îÄ */
.psl-head { text-align: center; margin-bottom: 40px; }
.psl-head h2 { font-size: clamp(22px,4vw,32px); font-weight:800; color:var(--psl-text); margin:0 0 8px; letter-spacing:-0.02em; }
.psl-head p  { font-size:14px; color:var(--psl-muted); margin:0 0 24px; }

.psl-score-pill {
  display:inline-flex; align-items:center; gap:14px; flex-wrap:wrap; justify-content:center;
  background:var(--psl-card-bg); border:1px solid var(--psl-border);
  border-radius:50px; padding:10px 24px;
}
.psl-score-num { font-size:28px; font-weight:800; color:var(--psl-text); line-height:1; }
.psl-score-stars { display:flex; gap:3px; }
.psl-score-stars svg { width:22px; height:22px; }
.psl-score-label { font-size:13px; color:var(--psl-muted); line-height:1.4; }
.psl-score-label strong { display:block; color:var(--psl-text); font-weight:700; }

/* ‚îÄ‚îÄ CAROUSEL ‚îÄ‚îÄ */
.psl-outer   { position:relative; max-width:1100px; margin:0 auto; }
.psl-clip    { overflow:hidden; }
.psl-track   {
  display:flex; gap:16px; align-items:stretch;
  transition: transform .45s cubic-bezier(.25,.46,.45,.94);
  will-change: transform;
}

/* ‚îÄ‚îÄ CARD ‚îÄ‚îÄ */
.psl-card {
  flex: 0 0 calc(33.333% - 11px);
  min-width:0; box-sizing:border-box;
  background:var(--psl-card-bg); border:1px solid var(--psl-border);
  border-radius:var(--psl-radius); padding:22px 20px 18px;
  display:flex; flex-direction:column; gap:10px;
}
@media(max-width:900px){ .psl-card { flex: 0 0 calc(50% - 8px); } }
@media(max-width:580px){ .psl-card { flex: 0 0 100%; } }

.psl-card-top  { display:flex; align-items:center; gap:12px; }
.psl-avatar    {
  width:40px; height:40px; border-radius:50%;
  background:var(--psl-green); color:#fff;
  font-size:14px; font-weight:700;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.psl-avatar.four { background:#3b82f6; }

.psl-rname   { font-size:14px; font-weight:700; color:var(--psl-text); }
.psl-vbadge  { display:inline-flex; align-items:center; gap:3px; font-size:11px; color:var(--psl-green); font-weight:600; margin-top:2px; }

.psl-stars   { display:flex; gap:2px; }
.psl-stars svg { width:15px; height:15px; }

.psl-rtitle  { font-size:14px; font-weight:700; color:var(--psl-text); line-height:1.4; margin:0; }
.psl-rbody   { font-size:13.5px; color:#374151; line-height:1.65; margin:0; flex:1; }

.psl-foot    {
  display:flex; align-items:center; justify-content:space-between;
  padding-top:10px; border-top:1px solid var(--psl-border); margin-top:auto;
}
.psl-date    { font-size:11px; color:#9ca3af; }
.psl-dot-tp  { width:7px; height:7px; border-radius:50%; background:#00B67A; }

/* ‚îÄ‚îÄ NAV ‚îÄ‚îÄ */
.psl-nav { display:flex; align-items:center; justify-content:center; gap:12px; margin-top:28px; }
.psl-btn {
  width:42px; height:42px; border-radius:50%;
  border:1.5px solid var(--psl-border); background:#fff; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  transition:all .2s; color:var(--psl-text);
}
.psl-btn:hover { background:var(--psl-green); border-color:var(--psl-green); color:#fff; }
.psl-btn svg   { width:18px; height:18px; }

.psl-dots { display:flex; gap:6px; }
.psl-dot  {
  width:8px; height:8px; border-radius:50%;
  background:var(--psl-border); cursor:pointer; border:none; padding:0;
  transition:all .25s;
}
.psl-dot.active { background:var(--psl-green); width:22px; border-radius:4px; }

/* ‚îÄ‚îÄ LEGAL ‚îÄ‚îÄ */
.psl-legal {
  text-align:center; font-size:11px; color:#c0c0c0;
  max-width:660px; margin:32px auto 0; line-height:1.6;
}
</style>

