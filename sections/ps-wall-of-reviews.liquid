{% comment %}
  ============================================================
  PHYTOSEED LABS ‚Äî Wall of Reviews (section √©ditable)
  A ajouter dans : Boutique en ligne ‚Üí Modifier le code ‚Üí Sections
  Nom du fichier sugg√©r√© : ps-wall-of-reviews.liquid
  ============================================================
{% endcomment %}

<style>
  .ps-wall {
    font-family: 'Poppins', 'Helvetica Neue', Arial, sans-serif;
    background: {{ section.settings.bg_color }};
    padding: 50px 20px;
    text-align: center;
  }

  .ps-wall__eyebrow {
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #8A7460;
    margin-bottom: 6px;
  }

  .ps-wall__title {
    font-size: 38px;
    font-weight: 800;
    color: #2E1D10;
    margin: 0 0 18px;
    line-height: 1.1;
  }

  .ps-wall__title span { color: #C0762E; }

  .ps-wall__stars-row {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #FFFDF8;
    border: 1.5px solid #E9D3B4;
    border-radius: 999px;
    padding: 8px 20px;
    margin-bottom: 36px;
  }

  .ps-wall__stars { display: flex; gap: 2px; }

  .ps-wall__star {
    width: 20px; height: 20px; border-radius: 4px;
    background: linear-gradient(135deg, #E7A65C 0%, #C0762E 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .ps-wall__star svg { width: 11px; height: 11px; fill: #FFF8EC; }

  .ps-wall__stars-text { font-size: 14px; font-weight: 700; color: #3A2416; }
  .ps-wall__stars-text b { color: #C0762E; }

  .ps-wall__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ps-wall__card {
    background: #FFFDF8;
    border: 1px solid #E9D3B4;
    border-radius: 16px;
    overflow: hidden;
    text-align: left;
    display: flex;
    flex-direction: column;
  }

  .ps-wall__photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #EFE1CC;
  }

  .ps-wall__photo img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  .ps-wall__photo-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: #C0A97E; font-size: 12px; text-align: center; padding: 6px;
  }

  .ps-wall__body { padding: 14px 16px 18px; }

  .ps-wall__mini-stars { display: flex; gap: 2px; margin-bottom: 8px; }

  .ps-wall__mini-star {
    width: 14px; height: 14px; border-radius: 3px;
    background: linear-gradient(135deg, #E7A65C 0%, #C0762E 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .ps-wall__mini-star svg { width: 8px; height: 8px; fill: #FFF8EC; }
  .ps-wall__mini-star--empty { background: #E9D3B4; }

  .ps-wall__quote { font-size: 13.5px; line-height: 1.45; color: #3A2416; margin: 0 0 10px; }
  .ps-wall__name { font-size: 12.5px; font-weight: 700; color: #8A7460; }

  @media (max-width: 900px) {
    .ps-wall__grid { grid-template-columns: repeat(2, 1fr); }
    .ps-wall__title { font-size: 28px; }
  }
  @media (max-width: 480px) {
    .ps-wall__grid { grid-template-columns: 1fr; }
  }
</style>

<div class="ps-wall">

  {% if section.settings.eyebrow != blank %}
    <div class="ps-wall__eyebrow">{{ section.settings.eyebrow }}</div>
  {% endif %}

  <h2 class="ps-wall__title">{{ section.settings.title }}</h2>

  <div class="ps-wall__stars-row">
    <div class="ps-wall__stars">
      {% for i in (1..5) %}
        <div class="ps-wall__star">
          <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431L24 9.168l-6 5.847L19.335 24 12 19.897 4.665 24 6 15.015 0 9.168l8.332-1.15z"/></svg>
        </div>
      {% endfor %}
    </div>
    <span class="ps-wall__stars-text"><b>{{ section.settings.rating }}</b> ¬∑ {{ section.settings.rating_label }} ¬∑ {{ section.settings.review_count }}</span>
  </div>

  <div class="ps-wall__grid">
    {% for block in section.blocks %}
      <div class="ps-wall__card" {{ block.shopify_attributes }}>
        <div class="ps-wall__photo">
          {% if block.settings.photo != blank %}
            <img src="{{ block.settings.photo | image_url: width: 600 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
          {% else %}
            <div class="ps-wall__photo-placeholder">Photo client<br>√† ajouter</div>
          {% endif %}
        </div>
        <div class="ps-wall__body">
          <div class="ps-wall__mini-stars">
            {% for i in (1..5) %}
              {% if i <= block.settings.stars %}
                <div class="ps-wall__mini-star"><svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431L24 9.168l-6 5.847L19.335 24 12 19.897 4.665 24 6 15.015 0 9.168l8.332-1.15z"/></svg></div>
              {% else %}
                <div class="ps-wall__mini-star ps-wall__mini-star--empty"></div>
              {% endif %}
            {% endfor %}
          </div>
          <p class="ps-wall__quote">"{{ block.settings.quote }}"</p>
          <div class="ps-wall__name">{{ block.settings.name }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "PS Wall of Reviews",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Petit texte au-dessus du titre",
      "default": "Phytoseed Labs"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "+1,900 Happy Customers"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Note (ex: 4.8/5)",
      "default": "4.8/5"
    },
    {
      "type": "text",
      "id": "rating_label",
      "label": "Libell√© (ex: Excellent)",
      "default": "Excellent"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Nombre d'avis (ex: +4,000 verified reviews)",
      "default": "+4,000 verified reviews"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Colonnes (desktop)",
      "default": "4",
      "options": [
        { "value": "2", "label": "2 colonnes" },
        { "value": "3", "label": "3 colonnes" },
        { "value": "4", "label": "4 colonnes" }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#F4EBDD"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Avis client",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo client"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Note (√©toiles)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Texte de l'avis",
          "default": "R√©sultat bluffant, un vrai h√¢le naturel sans passer des heures au soleil."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nom du client",
          "default": "Camille R."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PS Wall of Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}

