{%- comment -%}
  Snippet: Payment Badges Row
  Self-contained: all logos are inline SVG, no external requests,
  so nothing can ever fail to load or get blocked by hotlink protection.

  Usage: {% render 'payment-badges' %}
  Optional: {% render 'payment-badges', badge_height: 32 %}
{%- endcomment -%}

{%- assign badge_height = badge_height | default: 34 -%}

<div class="payment-badges-row" style="--pb-height: {{ badge_height }}px;">

  <span class="payment-badge payment-badge--amex" aria-label="American Express">
    <svg viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" role="img">
      <rect width="60" height="40" rx="7" fill="#1F72CD"/>
      <text x="30" y="25" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="13" font-weight="800" fill="#FFFFFF" letter-spacing="0.3">AMEX</text>
    </svg>
  </span>

  <span class="payment-badge payment-badge--applepay" aria-label="Apple Pay">
    <svg viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" role="img">
