      <rect x="0.5" y="0.5" width="59" height="39" rx="7" fill="#FFFFFF" stroke="#E1E1E1"/>
      <g>
        <path d="M27.85 20.27v2.94h-.93v-7.31h2.49c.63 0 1.17.21 1.6.63.45.42.67.93.67 1.54 0 .62-.22 1.14-.67 1.55-.43.42-.97.63-1.6.63h-1.56Zm0-3.5v2.63h1.58c.37 0 .68-.13.93-.38.26-.25.38-.55.38-.92 0-.36-.12-.66-.38-.9a1.25 1.25 0 0 0-.93-.39h-1.58Z" fill="#5F6368"/>
