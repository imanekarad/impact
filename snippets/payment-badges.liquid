      </g>
    </svg>
  </span>

  <span class="payment-badge payment-badge--mastercard" aria-label="Mastercard">
    <svg viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" role="img">
      <rect width="60" height="40" rx="7" fill="#000000"/>
      <circle cx="25" cy="20" r="9" fill="#EB001B"/>
      <circle cx="35" cy="20" r="9" fill="#F79E1B"/>
      <path d="M30 13.5a9 9 0 0 1 0 13 9 9 0 0 1 0-13Z" fill="#FF5F00"/>
    </svg>
  </span>

  <span class="payment-badge payment-badge--paypal" aria-label="PayPal">
    <svg viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" role="img">
      <rect x="0.5" y="0.5" width="59" height="39" rx="7" fill="#FFFFFF" stroke="#E1E1E1"/>
      <text x="30" y="25" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="13" font-weight="800" font-style="italic">
        <tspan fill="#003087">Pay</tspan><tspan fill="#009CDE">Pal</tspan>
      </text>
    </svg>
  </span>

  <span class="payment-badge payment-badge--shop" aria-label="Shop Pay">
    <svg viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" role="img">
      <rect width="60" height="40" rx="7" fill="#5A31F4"/>
      <text x="30" y="25" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="15" font-weight="700" font-style="italic" fill="#FFFFFF">shop</text>
    </svg>
  </span>

  <span class="payment-badge payment-badge--visa" aria-label="Visa">
    <svg viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" role="img">
      <rect width="60" height="40" rx="7" fill="#1434CB"/>
      <text x="30" y="25" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="15" font-weight="800" font-style="italic" fill="#FFFFFF" letter-spacing="0.5">VISA</text>
    </svg>
  </span>

</div>

<style>
  .payment-badges-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
  }

  .payment-badge {
    display: inline-flex;
    line-height: 0;
  }

  .payment-badge svg {
    height: var(--pb-height, 34px);
    width: auto;
    display: block;
  }

  @media (max-width: 480px) {
    .payment-badges-row {
      gap: 7px;
    }
  }
</style>






