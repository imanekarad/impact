        <path d="M39.86 26.3v-1.33c.11.02.38.03.51.03.72 0 1.12-.3 1.36-1.08 0-.02.14-.47.14-.48l-2.75-7.86h1.79l1.93 6.4h.03l1.93-6.4h1.75l-2.85 8.24c-.65 1.85-1.4 2.45-2.98 2.45-.12 0-.55-.01-.86-.06Z"/>
      </g>
    </svg>
  </span>

