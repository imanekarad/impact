        <path d="M27.6 12.6c2.13 0 3.61 1.47 3.61 3.6s-1.51 3.62-3.66 3.62h-2.36v3.75h-1.71V12.6h4.12Zm-2.41 5.83h1.96c1.48 0 2.33-.8 2.33-2.22s-.85-2.22-2.32-2.22h-1.97v4.44Z"/>
