        <path d="M23.6 19.7c0-.28-.02-.55-.07-.81h-3.85v1.5h2.2c-.09.51-.38.95-.82 1.24v1.02h1.32c.77-.71 1.22-1.76 1.22-2.95Z" fill="#4285F4"/>
        <path d="M19.68 23.34c1.1 0 2.03-.36 2.7-.99l-1.32-1.02c-.37.25-.84.39-1.38.39-1.06 0-1.96-.72-2.28-1.68h-1.36v1.05c.67 1.34 2.05 2.25 3.64 2.25Z" fill="#34A853"/>
